CREATE TABLE klien_aktif (
    nomor_wa VARCHAR(30) PRIMARY KEY,
    nama_toko VARCHAR(100) NOT NULL,
    email_laporan VARCHAR(100) NOT NULL
);

CREATE TABLE transaksi_harian (
    id SERIAL PRIMARY KEY,
    nomor_wa_klien VARCHAR(30) REFERENCES klien_aktif(nomor_wa),
    nama_barang VARCHAR(150) NOT NULL,
    qty INTEGER NOT NULL,
    total_harga NUMERIC NOT NULL,
    waktu_transaksi TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
